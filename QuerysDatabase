CREATE DATABASE `casa_descanso`

-- casa_descanso.attendance definition

CREATE TABLE `attendance` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `UserId` int NOT NULL,
  `CheckIn` datetime NOT NULL,
  `CheckOut` datetime DEFAULT NULL,
  `Date` date NOT NULL,
  `Notes` text COLLATE utf8mb4_unicode_ci,
  `Status` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  PRIMARY KEY (`Id`),
  KEY `IDX_Attendance_UserId` (`UserId`),
  KEY `IDX_Attendance_Date` (`Date`),
  CONSTRAINT `FK_Attendance_UserAccounts` FOREIGN KEY (`UserId`) REFERENCES `useraccounts` (`Id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=23 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.diettypes definition

CREATE TABLE `diettypes` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `Name` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `Description` text COLLATE utf8mb4_unicode_ci,
  PRIMARY KEY (`Id`),
  UNIQUE KEY `Name` (`Name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.incidents definition

CREATE TABLE `incidents` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `ResidentId` int NOT NULL,
  `RegisteredByUserId` int NOT NULL,
  `Date` datetime NOT NULL,
  `Type` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `SeverityLevel` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `Description` text COLLATE utf8mb4_unicode_ci NOT NULL,
  `Resolved` tinyint(1) NOT NULL DEFAULT '0',
  `ResolvedAt` datetime DEFAULT NULL,
  `CreatedAt` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`Id`),
  KEY `FK_Incidents_UserAccounts` (`RegisteredByUserId`),
  KEY `IDX_Incidents_ResidentId` (`ResidentId`),
  CONSTRAINT `FK_Incidents_Residents` FOREIGN KEY (`ResidentId`) REFERENCES `residents` (`Id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `FK_Incidents_UserAccounts` FOREIGN KEY (`RegisteredByUserId`) REFERENCES `useraccounts` (`Id`) ON DELETE RESTRICT ON UPDATE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.residentdiets definition

CREATE TABLE `residentdiets` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `ResidentId` int NOT NULL,
  `DietTypeId` int NOT NULL,
  `StartDate` date NOT NULL,
  `EndDate` date DEFAULT NULL,
  PRIMARY KEY (`Id`),
  KEY `FK_ResidentDiets_DietTypes` (`DietTypeId`),
  KEY `IDX_ResidentDiets_ResidentId` (`ResidentId`),
  CONSTRAINT `FK_ResidentDiets_DietTypes` FOREIGN KEY (`DietTypeId`) REFERENCES `diettypes` (`Id`) ON DELETE RESTRICT ON UPDATE CASCADE,
  CONSTRAINT `FK_ResidentDiets_Residents` FOREIGN KEY (`ResidentId`) REFERENCES `residents` (`Id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.residents definition

CREATE TABLE `residents` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `FirstName` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `LastName` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `MiddleName` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `BirthDate` date NOT NULL,
  `Gender` varchar(20) COLLATE utf8mb4_unicode_ci NOT NULL,
  `NSS` varchar(20) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `PhotoPath` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `EmergencyContactName` varchar(150) COLLATE utf8mb4_unicode_ci NOT NULL,
  `EmergencyContactPhone` varchar(20) COLLATE utf8mb4_unicode_ci NOT NULL,
  `EmergencyContactRelation` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `SecondContactName` varchar(150) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `SecondContactPhone` varchar(20) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `DiagnosedDiseases` text COLLATE utf8mb4_unicode_ci,
  `Allergies` text COLLATE utf8mb4_unicode_ci,
  `BloodType` varchar(5) COLLATE utf8mb4_unicode_ci NOT NULL,
  `AdmissionDate` date NOT NULL,
  `Observations` text COLLATE utf8mb4_unicode_ci,
  `IsActive` tinyint(1) NOT NULL DEFAULT '1',
  `CreatedAt` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`Id`),
  UNIQUE KEY `NSS` (`NSS`),
  KEY `IDX_Residents_LastName` (`LastName`)
) ENGINE=InnoDB AUTO_INCREMENT=5 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.roles definition

CREATE TABLE `roles` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `Name` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `Description` varchar(150) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `IsActive` tinyint(1) NOT NULL DEFAULT '1',
  `CreatedAt` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`Id`),
  UNIQUE KEY `Name` (`Name`)
) ENGINE=InnoDB AUTO_INCREMENT=6 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.shifts definition

CREATE TABLE `shifts` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `Name` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `StartTime` time NOT NULL,
  `EndTime` time NOT NULL,
  PRIMARY KEY (`Id`),
  UNIQUE KEY `Name` (`Name`)
) ENGINE=InnoDB AUTO_INCREMENT=6 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.useraccounts definition

CREATE TABLE `useraccounts` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `WorkerId` int NOT NULL,
  `Username` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `PasswordHash` varchar(255) COLLATE utf8mb4_unicode_ci NOT NULL,
  `RoleId` int NOT NULL,
  `IsActive` tinyint(1) NOT NULL DEFAULT '1',
  `CreatedAt` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`Id`),
  UNIQUE KEY `Username` (`Username`),
  KEY `IDX_UserAccounts_WorkerId` (`WorkerId`),
  KEY `IDX_UserAccounts_RoleId` (`RoleId`),
  CONSTRAINT `FK_UserAccounts_Roles` FOREIGN KEY (`RoleId`) REFERENCES `roles` (`Id`) ON DELETE RESTRICT ON UPDATE CASCADE,
  CONSTRAINT `FK_UserAccounts_Workers` FOREIGN KEY (`WorkerId`) REFERENCES `workers` (`Id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=17 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.vitalsigns definition

CREATE TABLE `vitalsigns` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `ResidentId` int NOT NULL,
  `RecordedByUserId` int NOT NULL,
  `Temperature` decimal(5,2) DEFAULT NULL,
  `BloodPressure` varchar(20) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `HeartRate` int DEFAULT NULL,
  `OxygenSaturation` decimal(5,2) DEFAULT NULL,
  `GlucoseLevel` decimal(6,2) DEFAULT NULL,
  `Weight` decimal(6,2) DEFAULT NULL,
  `Notes` text COLLATE utf8mb4_unicode_ci,
  `RecordedAt` datetime NOT NULL,
  `RespiratoryFrequency` int DEFAULT NULL,
  PRIMARY KEY (`Id`),
  KEY `FK_VitalSigns_UserAccounts` (`RecordedByUserId`),
  KEY `IDX_VitalSigns_ResidentId` (`ResidentId`),
  CONSTRAINT `FK_VitalSigns_Residents` FOREIGN KEY (`ResidentId`) REFERENCES `residents` (`Id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `FK_VitalSigns_UserAccounts` FOREIGN KEY (`RecordedByUserId`) REFERENCES `useraccounts` (`Id`) ON DELETE RESTRICT ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=5 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- casa_descanso.workers definition

CREATE TABLE `workers` (
  `Id` int NOT NULL AUTO_INCREMENT,
  `FirstName` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `LastName` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `MiddleName` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `BirthDate` date NOT NULL,
  `Gender` varchar(20) COLLATE utf8mb4_unicode_ci NOT NULL,
  `PhotoPath` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `Phone` varchar(20) COLLATE utf8mb4_unicode_ci NOT NULL,
  `Email` varchar(150) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `EmergencyContactName` varchar(150) COLLATE utf8mb4_unicode_ci NOT NULL,
  `EmergencyContactPhone` varchar(20) COLLATE utf8mb4_unicode_ci NOT NULL,
  `RFC` varchar(13) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `CURP` varchar(18) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `NSS` varchar(20) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `RoleId` int NOT NULL,
  `EducationLevel` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `Allergies` text COLLATE utf8mb4_unicode_ci,
  `ShiftId` int NOT NULL,
  `IsActive` tinyint(1) NOT NULL DEFAULT '1',
  `CreatedAt` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`Id`),
  UNIQUE KEY `RFC` (`RFC`),
  UNIQUE KEY `CURP` (`CURP`),
  UNIQUE KEY `NSS` (`NSS`),
  KEY `IDX_Workers_LastName` (`LastName`),
  KEY `IDX_Workers_ShiftId` (`ShiftId`),
  CONSTRAINT `FK_Workers_Shifts` FOREIGN KEY (`ShiftId`) REFERENCES `shifts` (`Id`) ON DELETE RESTRICT ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=17 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

